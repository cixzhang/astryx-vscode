{
  "name": "astryx-vscode",
  "displayName": "Astryx for VS Code",
  "description": "Astryx design system themes and live component preview for VS Code",
  "version": "0.1.0",
  "publisher": "cixzhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cixzhang/astryx-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Themes", "Other"],
  "keywords": ["astryx", "design system", "theme", "meta", "stylex"],
  "icon": "media/icon.png",
  "activationEvents": ["onCommand:astryx.showPreview"],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Astryx Neutral Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/astryx-neutral-dark.json"
      },
      {
        "label": "Astryx Neutral Light",
        "uiTheme": "vs",
        "path": "./themes/astryx-neutral-light.json"
      }
    ],
    "commands": [
      {
        "command": "astryx.showPreview",
        "title": "Astryx: Show Component Preview",
        "category": "Astryx"
      },
      {
        "command": "astryx.selectTheme",
        "title": "Astryx: Select Astryx Theme",
        "category": "Astryx"
      }
    ],
    "configuration": {
      "title": "Astryx",
      "properties": {
        "astryx.preview.themeName": {
          "type": "string",
          "default": "neutral",
          "enum": ["neutral", "stone", "matcha", "y2k", "chocolate", "butter", "gothic"],
          "enumDescriptions": [
            "Neutral — monochrome, the default Astryx theme",
            "Stone — warm neutral tones",
            "Matcha — green-tinted",
            "Y2K — retro 2000s aesthetic",
            "Chocolate — warm brown tones",
            "Butter — soft yellow tones",
            "Gothic — dark gothic aesthetic"
          ],
          "description": "Which Astryx theme to use in the component preview webview"
        },
        "astryx.preview.colorMode": {
          "type": "string",
          "default": "dark",
          "enum": ["light", "dark"],
          "description": "Color mode for the component preview"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-yarn",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
