{
  "name": "astryx-vscode",
  "displayName": "Astryx for VS Code",
  "description": "Astryx design system component preview that matches your current VS Code theme",
  "version": "0.3.0",
  "publisher": "cixzhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cixzhang/astryx-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "astryx",
    "design system",
    "theme",
    "meta",
    "stylex"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onCommand:astryx.showPreview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "astryx.showPreview",
        "title": "Astryx: Show Component Preview",
        "category": "Astryx"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-yarn",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.2",
    "@astryxdesign/core": "^0.1.2",
    "@astryxdesign/theme-neutral": "^0.1.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
