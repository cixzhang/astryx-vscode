  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#737373"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#005600"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#6e3500"
      }
    },
    {
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#6e3500"
      }
    },
    {
      "scope": [
        "constant.character"
      ],
      "settings": {
        "foreground": "#6e3500"
      }
    },
    {
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#700084"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#700084"
      }
    },
    {
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#00458c"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#700084"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#171717"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#171717"
      }
    },
    {
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#700084"
      }
    },
    {
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#a3a3a3"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#737373"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#89001a"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#584400"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#005348"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#005600"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#700084"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#00458c"
      }
    },
    {
      "scope": [
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#700084"
      }
    }
  ]
}