{
  "name": "Astryx Neutral Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#fafafa",
    "editor.foreground": "#171717",
    "editorLineNumber.foreground": "#737373",
    "editorLineNumber.activeForeground": "#171717",
    "editorCursor.foreground": "#262626",
    "editor.selectionBackground": "#0000001A",
    "editor.selectionHighlightBackground": "#0000000D",
    "editor.lineHighlightBackground": "#f1f1f1",
    "editor.lineHighlightBorder": "#00000000",
    "editorIndentGuide.background": "#ebebeb",
    "editorIndentGuide.activeBackground": "#d4d4d4",
    "editorBracketMatch.background": "#0000000D",
    "editorBracketMatch.border": "#d4d4d4",
    "editor.findMatchBackground": "#0000001A",
    "editor.findMatchHighlightBackground": "#0000000D",
    "editorGroup.background": "#f1f1f1",
