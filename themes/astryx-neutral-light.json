    "sideBarTitle.foreground": "#171717",
    "sideBarSectionHeader.background": "#f1f1f1",
    "sideBar.border": "#ebebeb",
    "tab.activeBackground": "#ffffff",
    "tab.activeForeground": "#171717",
    "tab.inactiveBackground": "#f1f1f1",
    "tab.inactiveForeground": "#737373",
    "tab.border": "#ebebeb",
    "tab.activeBorderTop": "#262626",
    "statusBar.background": "#f1f1f1",
    "statusBar.foreground": "#737373",
    "statusBar.debuggingBackground": "#a50c25",
    "statusBar.noFolderBackground": "#f1f1f1",
    "titleBar.activeBackground": "#f1f1f1",
    "titleBar.activeForeground": "#171717",
    "titleBar.inactiveBackground": "#f1f1f1",
    "titleBar.inactiveForeground": "#737373",
    "panel.background": "#f1f1f1",
    "panel.border": "#ebebeb",
    "panelTitle.activeForeground": "#171717",
    "panelTitle.inactiveForeground": "#737373",
    "input.background": "#ffffff",
    "input.border": "#ebebeb",
    "input.foreground": "#171717",
    "input.placeholderForeground": "#737373",
    "inputOption.activeBorder": "#262626",
    "list.activeSelectionBackground": "#0000001A",
    "list.activeSelectionForeground": "#171717",
    "list.hoverBackground": "#0000000D",
    "list.inactiveSelectionBackground": "#f1f1f1",
    "list.inactiveSelectionForeground": "#171717",
    "button.background": "#262626",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#0000001A",
    "dropdown.background": "#ffffff",
    "dropdown.border": "#ebebeb",
    "dropdown.foreground": "#171717",
    "scrollbar.shadow": "#0000001A",
    "scrollbarSlider.background": "#0000000F",
    "scrollbarSlider.hoverBackground": "#0000000D",
    "scrollbarSlider.activeBackground": "#0000001A",
    "minimap.background": "#f1f1f1",
    "peekView.background": "#ffffff",
    "peekView.border": "#262626",
    "peekViewTitle.background": "#f1f1f1",
    "gitDecoration.modifiedResourceForeground": "#00458c",
    "gitDecoration.untrackedResourceForeground": "#0c5700",
    "gitDecoration.deletedResourceForeground": "#89001a",
    "gitDecoration.conflictingResourceForeground": "#745b00",
    "notifications.background": "#ffffff",
    "notifications.foreground": "#171717",
    "notification.background": "#ffffff",
    "notification.foreground": "#171717",
    "notification.buttonBackground": "#262626",
    "notification.buttonForeground": "#ffffff",
    "breadcrumb.background": "#ffffff",
    "breadcrumb.foreground": "#737373",
    "breadcrumb.focusForeground": "#171717",
    "widget.shadow": "#0000001A",
    "badge.background": "#262626",
    "badge.foreground": "#ffffff"
