  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a3a3a3"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#a6d2a2"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ffb37f"
      }
    },
    {
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#ffb37f"
      }
    },
    {
      "scope": [
        "constant.character"
      ],
      "settings": {
        "foreground": "#ffb37f"
      }
    },
    {
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#efa8ff"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#efa8ff"
      }
    },
    {
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#a0caff"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#efa8ff"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#e5e5e5"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#e5e5e5"
      }
    },
    {
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#efa8ff"
      }
    },
    {
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#525252"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#a3a3a3"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ffaeaa"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
